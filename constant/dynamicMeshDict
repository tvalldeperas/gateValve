dynamicFvMesh   dynamicMotionSolverFvMesh;
motionSolverLibs ("libfvMotionSolvers.so");
solver    solidBody;

solidBodyCoeffs
{
    cellZone        CREATED_MATERIAL_7;
    solidBodyMotionFunction  rotatingMotion;
    
    rotatingMotionCoeffs
    {
        origin    (0 0 0);
        axis      (0 0 1);

        omega     151.84;     // - PUMP // + TURB

