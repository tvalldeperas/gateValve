FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

libs            ("libturbulenceModelSchemes.so");

application     pimpleFoam;

startFrom       latestTime;
startTime       0;
stopAt          endTime;

// PIMPLE values 35RPM = 10 start + 25 analysis
endTime         1.45;                  // 35  rev  
deltaT          1.1494e-4;             // 1.0 deg 
writeInterval   0.2069;                // 5.0 rev
purgeWrite      5;                     // 25  rev = 5 rev x 5 intervals

// moveMesh values
//endTime         1.0;               
//deltaT          0.1;  
//writeInterval   0.1;               


writeControl    adjustableRunTime; 
writeLast       yes;                
writeFormat     binary;         //ascii
writePrecision  7;
writeCompression off;
timeFormat      general;
timePrecision   6;
runTimeModifiable true;
adjustTimeStep  no;
maxCo           150;            // conservative during ramp
minDeltaT       1e-8;           // hard bottom on Δt
maxDeltaT       2e-4;           // hard ceiling on Δt
rDeltaTSmoothingCoeff 0.1;      // smooth Δt changes
rDeltaTDampingCoeff   0.5;      // damp sudden increases



functions
{


   
    
    Qfield
    {
        type            Q;
        libs            ("libfieldFunctionObjects.so");

        writeControl    writeTime;
        writeInterval   1;

        field           U;
        result          Q;
    }
    
    // --- Fluxes on patches (every time step, light output) ---

    Q_DUCTIN_IMPELLER
    {
        type            surfaceFieldValue;
        libs            ( fieldFunctionObjects );
        operation       sum;
        fields          ( phi );
        regionType      patch;
        name            INTERFACE_DUCTIN_IMPELLER_AMI;

        executeControl  timeStep;
        executeInterval 1;
        writeControl    timeStep;
        writeInterval   1;

        writeFields     false;
        log             false;
    }

    Q_IMPELLER_DUCTIN
    {
        type            surfaceFieldValue;
        libs            ( fieldFunctionObjects );
        operation       sum;
        fields          ( phi );
        regionType      patch;
        name            INTERFACE_IMPELLER_DUCTIN_AMI;

        executeControl  timeStep;
        executeInterval 1;
        writeControl    timeStep;
        writeInterval   1;

        writeFields     false;
        log             false;
    }
    
    Q_IMPELLER_VOLUTE
    {
        type            surfaceFieldValue;
        libs            ( fieldFunctionObjects );
        operation       sum;
        fields          ( phi );
        regionType      patch;
        name            INTERFACE_IMPELLER_VOLUTE_AMI;

        executeControl  timeStep;
        executeInterval 1;
        writeControl    timeStep;
        writeInterval   1;

        writeFields     false;
        log             false;
    }

    Q_VOLUTE_IMPELLER
    {
        type            surfaceFieldValue;
        libs            ( fieldFunctionObjects );
        operation       sum;
        fields          ( phi );
        regionType      patch;
        name            INTERFACE_VOLUTE_IMPELLER_AMI;

        executeControl  timeStep;
        executeInterval 1;
        writeControl    timeStep;
        writeInterval   1;

        writeFields     false;
        log             false;
    }

    Q_inlet
    {
        type            surfaceFieldValue;
        libs            ( fieldFunctionObjects );
        regionType      patch;
        name            inlet;
        fields          ( phi );
        operation       sum;

        executeControl  timeStep;
        executeInterval 1;
        writeControl    timeStep;
        writeInterval   1;

        writeFields     false;
        log             false;
    }

    Q_outlet
    {
        type            surfaceFieldValue;
        libs            ( fieldFunctionObjects );
        regionType      patch;
        name            outlet;
        fields          ( phi );
        operation       sum;

        executeControl  timeStep;
        executeInterval 1;
        writeControl    timeStep;
        writeInterval   1;

        writeFields     false;
        log             false;
    }


    // --- Vorticity: only at write times (when fields are written) ---

    vorticityVec
    {
        type            vorticity;
        libs            ( fieldFunctionObjects );
        U               U;
        result          vorticityVec;
        write           yes;

        executeControl  writeTime;
        writeControl    writeTime;
        writeFields     false;   // only result field, and only when main fields are written
        log             false;
    }


    // --- Residuals: every time step (this is lightweight and useful) ---

    residuals
    {
        type            solverInfo;
        libs            ( utilityFunctionObjects );
        fields          ( p U k nut omega );

        executeControl  timeStep;
        executeInterval 1;
        writeControl    timeStep;
        writeInterval   1;
    }


    // --- yPlus: only at write times, like vorticity ---

    yPlus
    {
        type            yPlus;
        libs            ( "libfieldFunctionObjects.so" );
        patches         ( "B_RUNNER_BLADE B_RUNNER_HUB B_RUNNER_SHROUD C_VOLUTE_WALL" );

        executeControl  writeTime;
        writeControl    writeTime;
        writeFields     false;
        log             false;
    }


    // --- fieldAveraging: writes the flow fields averaged from timeStart to writeTime ---

    fieldAveraging
    {
        type            fieldAverage;
        libs            (fieldFunctionObjects);

        timeStart       0.4137931;  // start averaging only after timeStart (10 rev)
        executeControl  writeTime;
        writeControl    writeTime;
        writeFields     false;
        log             false;

        fields
        (
            U
            {
                mean        on;
                prime2Mean  on;
                base        time;
            }
            p
            {
                mean        on;
                prime2Mean  on;
                base        time;
            }
            k
            {
                mean        on;
                prime2Mean  on;
                base        time;
            }
            omega
            {
                mean        on;
                prime2Mean  on;
                base        time;
            }
        );
    }


    // --- Total pressure field p0 and its mass-flow averages (every Δt) ---

    p0Field
    {
        type            pressure;
        libs            ( fieldFunctionObjects );
        mode            total;
        p               p;
        U               U;
        rho             rhoInf;
        rhoInf          1000;
        result          p0;
        write           yes;

        // compute p0 every timeStep (in-memory)
        executeControl  timeStep;
        executeInterval 1;

        // write p0 field ONLY when the solver writes fields
        writeControl    writeTime;
        writeInterval   1;

        writeFields     false;
        log             false;
    }

    p0_mdotAvg_inlet
    {
        type            surfaceFieldValue;
        libs            ( fieldFunctionObjects );
        regionType      patch;
        name            inlet;
        fields          ( p0 );
        operation       absWeightedAverage;
        weightField     phi;

        executeControl  timeStep;
        executeInterval 1;
        writeControl    timeStep;
        writeInterval   1;

        writeFields     false;
        log             false;
    }

    p0_mdotAvg_outlet
    {
        type            surfaceFieldValue;
        libs            ( fieldFunctionObjects );
        regionType      patch;
        name            outlet;
        fields          ( p0 );
        operation       absWeightedAverage;
        weightField     phi;

        executeControl  timeStep;
        executeInterval 1;
        writeControl    timeStep;
        writeInterval   1;

        writeFields     false;
        log             false;
    }


    // --- Impeller forces (torque) every time step ---

    impellerForces
    {
        type            forces;
        libs            ( "libforces.so" );
        patches         (B_RUNNER_BLADE B_RUNNER_HUB B_RUNNER_SHROUD A_DUCTIN_WALL_MOVE);
        pRef            0;
        CofR            ( 0 0 0 );
        rho             rhoInf;
        rhoInf          1000;

        executeControl  timeStep;
        executeInterval 1;
        writeControl    timeStep;
        writeInterval   1;

        writeFields     false;
        log             false;
    }

    volutMonitors
    {
        type            probes;
        libs            ("libsampling.so");

        fields          (p p0 U);  // include p0 if you want total-pressure based head
        probeLocations
        (
                        ( 0.000  0.208  0.045)                 // PAT Inlet   1
                        (-0.026  0.118  0.045)                 // Tongue      2
                        (-0.0600000000  0.1039230485  0.045)   // Monitor     3
                        (-0.1187928495  0.0169707050  0.045)   // Monitor     4
                        (-0.0881904509 -0.0813713660  0.045)   // Monitor     5
                        ( 0.0089055846 -0.1196691122  0.045)   // Monitor     6
                        ( 0.0992953829 -0.0673704699  0.045)   // Monitor     7
                        ( 0.1149032300  0.0346198610  0.045)   // Monitor     8
                        ( 0.0438791029  0.1118973337  0.045)   // Monitor     9 
                        ( 0.000  0.037  0.012)                 // Imp. outlet 10 
                        ( 0.000  0.000 -0.035)                 // PAT outlet  11
        );

        executeControl  timeStep;
        executeInterval 1;
        writeControl    timeStep;
        writeInterval   1;
    }


}


