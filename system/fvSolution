FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{

    Phi
    {
        solver          GAMG;
        tolerance       1e-8;
        relTol          0;
        smoother        GaussSeidel;
        nPreSweeps      0;
        nPostSweeps     2;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 10;
        agglomerator    faceAreaPair;
        mergeLevels     1;
    }

    p
    {
        solver          GAMG;
        tolerance       1e-7;
        relTol          0.01;
        smoother        GaussSeidel;
        nCellsInCoarsestLevel 20;
        agglomerator    faceAreaPair;
        mergeLevels     1;
        
        minIter        2;     
        nFinestSweeps  2;
        nPreSweeps     2;
        nPostSweeps    2;
    }
    
    pFinal
    {
        $p;
        tolerance       1e-8;       
        relTol          0;

        minIter        2;
        nFinestSweeps  2;
        nPreSweeps     2;
        nPostSweeps    2;
    }
    
    pcorr
    {
        solver          GAMG;
        tolerance       1e-6;       
        relTol          0;
        smoother        DICGaussSeidel;
        agglomerator    faceAreaPair;
        cacheAgglomeration true;

        nCellsInCoarsestLevel 50;
        mergeLevels     1;

        // cheap V-cycle
        nFinestSweeps   2; // 2;
        nPreSweeps      1; // 0; 
        nPostSweeps     2; // 1;
        minIter         2; // 1;
        maxIter         50;
    }
    
    pcorrFinal
    {
        $pcorr;    
        tolerance       1e-7;
        // nPostSweeps     2;
        nPreSweeps      1; // added
        nPostSweeps     2; // added
    }
    
    U
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.1;
    }
    
    UFinal
    {
        $U;
        tolerance   1e-8;
        relTol      0;
    }
    
    k
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.1;
    }
    
    kFinal
    {
        $k;
        tolerance   1e-8;
        relTol      0;
    }
    
    omega
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-7;
        relTol          0.1;
    }
    
    omegaFinal
    {  
        $omega;
        tolerance   1e-8;
        relTol      0;
    }
}

PIMPLE
{
    momentumPredictor           true; 
    nOuterCorrectors            3;
    nCorrectors                 3;
    nNonOrthogonalCorrectors    3;
}

relaxationFactors
{
    equations
    {
        ".*"                    1;
    }
}

