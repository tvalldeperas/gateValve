FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    inlet
    {
        type	            flowRateInletVelocity;
        volumetricFlowRate  constant 0.021286;    // m3/s
        value               uniform (0 0 0);
    }

    outlet
    {
        type                zeroGradient;     // pressureInletOutletVelocity; // inletOutlet;
        // inletValue       $internalField;
        // value            $internalField;
    }

    "A_DUCTIN_WALL_STILL|C_VOLUTE_WALL|C_VOLUTE_GAP"
    {
        type                noSlip;
    }

    "B_RUNNER_BLADE|B_RUNNER_HUB|B_RUNNER_SHROUD|A_DUCTIN_WALL_MOVE"
    {
        type                movingWallVelocity;
        value               uniform (0 0 0);
    }
    
    
}


