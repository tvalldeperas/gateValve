FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 19.77;

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    inlet
    {
        type            fixedValue;
        value           $internalField;
    }

    outlet
    {
        type            zeroGradient;     //inletOutlet;
        //inletValue      $internalField;
        //value           $internalField;
    }

    "B_RUNNER_BLADE|B_RUNNER_HUB|B_RUNNER_SHROUD|A_DUCTIN_WALL_MOVE|A_DUCTIN_WALL_STILL|C_VOLUTE_WALL|C_VOLUTE_GAP"
    {
        type            omegaWallFunction;
        value           $internalField;
    }
}


